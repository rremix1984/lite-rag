# =============================================
# LiteRAG 环境变量配置说明
# 复制此文件为 server/.env 并填写对应值
# =============================================

# 服务端口（默认 3001）
SERVER_PORT=3001

# JWT 密钥（至少 32 位随机字符串）
JWT_SECRET=your-super-secret-jwt-key-at-least-32-chars
# JWT 有效期（默认 7 天）
JWT_EXPIRY=7d

# =============================================
# PostgreSQL 数据库连接
# =============================================
DATABASE_URL=postgresql://username:password@localhost:5432/lite_rag

# =============================================
# LLM 配置（OpenAI 兼容接口）
# =============================================
# 内部 LLM API 地址（兼容 OpenAI 格式）
LLM_BASE_URL=http://your-internal-llm-server/v1
# API Key（内部服务可填任意字符串）
LLM_API_KEY=your-api-key
# 默认使用的模型名称
LLM_MODEL=your-model-name
# 上下文窗口大小（token 数）
LLM_CONTEXT_WINDOW=4096

# =============================================
# Embedding 配置（OpenAI 兼容接口）
# 可以与 LLM 使用同一个服务，也可以分开
# =============================================
EMBEDDING_BASE_URL=http://your-internal-embedding-server/v1
EMBEDDING_API_KEY=your-embedding-api-key
# Embedding 模型名称
EMBEDDING_MODEL=your-embedding-model
# Embedding 向量维度（必须与模型一致，常见值：768 / 1024 / 1536）
EMBEDDING_DIMENSIONS=1536

# =============================================
# 其他配置
# =============================================
# 文件上传大小限制（MB）
MAX_UPLOAD_SIZE_MB=50
# 生产模式标识（生产环境设为 production）
NODE_ENV=development
